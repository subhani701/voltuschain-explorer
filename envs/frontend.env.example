# =============================================================================
# API ENDPOINTS
# =============================================================================
# These are client-side variables used by the browser
# Use nginx proxy to avoid CORS issues - frontend calls localhost/api which goes through nginx
NEXT_PUBLIC_APP_HOST=localhost
NEXT_PUBLIC_API_HOST=localhost
# Public proxy port (host side of the proxy mapping in docker-compose.yml)
NEXT_PUBLIC_API_PORT=8091
NEXT_PUBLIC_API_PROTOCOL=http
NEXT_PUBLIC_API_WEBSOCKET_PROTOCOL=ws

# Stats API - frontend will construct URLs like http://localhost:8091/api/v1/stats/...
# This goes through nginx proxy which handles CORS
NEXT_PUBLIC_STATS_API_HOST=http://localhost:8091

# Visualizer (routed through the nginx proxy to keep it same-origin and avoid
# CORS — the visualizer service itself sends no CORS headers).
NEXT_PUBLIC_VISUALIZE_API_HOST=http://localhost:8091

# =============================================================================
# NETWORK INFORMATION
# =============================================================================
NEXT_PUBLIC_NETWORK_NAME=Voltuswave
NEXT_PUBLIC_NETWORK_SHORT_NAME=Voltuswave
NEXT_PUBLIC_NETWORK_ID=1234567
# Point at your chain's public RPC endpoint (provided separately)
NEXT_PUBLIC_NETWORK_RPC_URL=http://YOUR_RPC_NODE_HOST

# Currency
NEXT_PUBLIC_NETWORK_CURRENCY_NAME=Voltus
NEXT_PUBLIC_NETWORK_CURRENCY_SYMBOL=VW
NEXT_PUBLIC_NETWORK_CURRENCY_DECIMALS=18

# Network type
NEXT_PUBLIC_IS_TESTNET=false
NEXT_PUBLIC_NETWORK_VERIFICATION_TYPE=validation

# =============================================================================
# UI CONFIGURATION
# =============================================================================
# Logo URLs - served via assets container (Docker network)
NEXT_PUBLIC_NETWORK_LOGO=http://bs-assets/logo.svg
NEXT_PUBLIC_NETWORK_LOGO_DARK=http://bs-assets/logo-dark.svg
NEXT_PUBLIC_NETWORK_ICON=http://bs-assets/icon.png
NEXT_PUBLIC_NETWORK_ICON_DARK=http://bs-assets/icon.png



# Homepage styling - using theme defaults for automatic adaptation
# NEXT_PUBLIC_HOMEPAGE_PLATE_BACKGROUND=
# NEXT_PUBLIC_HOMEPAGE_PLATE_TEXT_COLOR=

# Charts on homepage
NEXT_PUBLIC_HOMEPAGE_CHARTS=['daily_txs','coin_price','market_cap']
NEXT_PUBLIC_HOMEPAGE_SHOW_AVG_BLOCK_TIME=true

# =============================================================================
# WALLET (Connect / Write Contract)
# =============================================================================
# Required to enable the "Connect wallet" feature at all. Once set, wagmi
# auto-detects injected browser extensions (EIP-6963) such as VoltusWave Wallet.
# Users sign locally in the extension; the WalletConnect relay is only used for
# the QR-code path, not for injected connects. Get a free id at
# https://cloud.walletconnect.com  -> replace the placeholder below.
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# =============================================================================
# FEATURES
# =============================================================================
# Contract verification
NEXT_PUBLIC_CONTRACT_CODE_IDES=[{"title":"Remix","url":"https://remix.ethereum.org","icon_url":"https://remix.ethereum.org/favicon.ico"}]

# API documentation
NEXT_PUBLIC_API_SPEC_URL=https://raw.githubusercontent.com/blockscout/blockscout-api-v2-swagger/main/swagger.yaml

# Disable for private chains
NEXT_PUBLIC_IS_ACCOUNT_SUPPORTED=false
NEXT_PUBLIC_MARKETPLACE_ENABLED=false
NEXT_PUBLIC_HAS_BEACON_CHAIN=false

# Enable useful features
NEXT_PUBLIC_HAS_CONTRACT_AUDIT_REPORTS=false
# Transaction interpretation (set to false if causing issues)
# NEXT_PUBLIC_TRANSACTION_INTERPRETATION_ENABLED=false

# =============================================================================
# VALIDATORS PAGE
# =============================================================================
# Disabled - Clique PoA uses signers, not PoS validators
# Signers are visible in block details and blocks list
# NEXT_PUBLIC_VALIDATORS_CHAIN_TYPE=stability

# =============================================================================
# FOOTER
# =============================================================================
# Custom footer links (served from assets container)
NEXT_PUBLIC_FOOTER_LINKS=http://bs-assets/footer.json


# =============================================================================
# SEO & METADATA
# =============================================================================
NEXT_PUBLIC_OG_DESCRIPTION=Blockchain Explorer for Voltuswave PoA Network
NEXT_PUBLIC_OG_IMAGE_URL=
NEXT_PUBLIC_PROMOTE_BLOCKSCOUT_IN_TITLE=false

# =============================================================================
# EXTERNAL SERVICES (Disabled for private chains)
# =============================================================================
NEXT_PUBLIC_GAS_TRACKER_ENABLED=false

# Disable ads/banners
NEXT_PUBLIC_AD_BANNER_PROVIDER=none
NEXT_PUBLIC_AD_TEXT_PROVIDER=none
# GraphiQL transaction - must be empty or valid hex hash
# NEXT_PUBLIC_GRAPHIQL_TRANSACTION=
