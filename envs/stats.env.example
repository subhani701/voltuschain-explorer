STATS__SERVER__HTTP__ADDR=0.0.0.0:8050
STATS__SERVER__GRPC__ENABLED=false

# Database - replace CHANGE_ME with the real DB password (provided separately)
STATS__DB_URL=postgresql://blockscout:CHANGE_ME@db:5432/blockscout_stats
STATS__BLOCKSCOUT_DB_URL=postgresql://blockscout:CHANGE_ME@db:5432/blockscout

STATS__CREATE_DATABASE=true
STATS__RUN_MIGRATIONS=true

# Charts configuration - remove invalid charts field
# STATS__CHARTS__TEMPLATE_VALUES__NATIVE_COIN_SYMBOL=VW
STATS__FORCE_UPDATE_ON_START=true
