# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Replace CHANGE_ME with the real DB password (provided separately)
DATABASE_URL=postgresql://blockscout:CHANGE_ME@db:5432/blockscout
DATABASE_READ_ONLY_API_URL=postgresql://blockscout:CHANGE_ME@db:5432/blockscout
ECTO_USE_SSL=false
POOL_SIZE=80
POOL_SIZE_API=20

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# GETH POA CLIQUE - RPC CONFIGURATION
# =============================================================================
ETHEREUM_JSONRPC_VARIANT=geth
# Point these at your chain's RPC node (provided separately)
ETHEREUM_JSONRPC_HTTP_URL=http://YOUR_RPC_NODE_HOST
ETHEREUM_JSONRPC_TRACE_URL=http://YOUR_RPC_NODE_HOST
ETHEREUM_JSONRPC_WS_URL=ws://YOUR_RPC_NODE_HOST/ws

# Fallback RPC (optional - for redundancy)
# ETHEREUM_JSONRPC_FALLBACK_HTTP_URL=http://backup-node:8545
# ETHEREUM_JSONRPC_FALLBACK_TRACE_URL=http://backup-node:8545

# =============================================================================
# CHAIN CONFIGURATION - CUSTOMIZE FOR YOUR CHAIN
# =============================================================================
CHAIN_ID=1234567
NETWORK=Voltuswave
SUBNETWORK=PoA Clique Network
NETWORK_PATH=/

# Native coin configuration
COIN=VW
COIN_NAME=Voltus
COIN_SYMBOL=VW

# =============================================================================
# GETH CLIQUE SPECIFIC SETTINGS
# =============================================================================
# Clique block rewards (usually 0 for PoA, but set if you have rewards)
BLOCK_REWARD=0

# Emission format for PoA (no emission reduction like PoW)
EMISSION_FORMAT=DEFAULT

# Clique uses 0 gas for coinbase transactions
EIP_1559_ELASTICITY_MULTIPLIER=2

# =============================================================================
# INDEXER CONFIGURATION
# =============================================================================
INDEXER_DISABLE_PENDING_TRANSACTIONS_FETCHER=false
INDEXER_DISABLE_INTERNAL_TRANSACTIONS_FETCHER=false
INDEXER_DISABLE_BLOCK_REWARD_FETCHER=false
INDEXER_DISABLE_ADDRESS_COIN_BALANCE_FETCHER=false
INDEXER_DISABLE_CATALOGED_TOKEN_UPDATER_FETCHER=false
INDEXER_DISABLE_TOKEN_INSTANCE_REALTIME_FETCHER=false
INDEXER_DISABLE_TOKEN_INSTANCE_RETRY_FETCHER=false
INDEXER_DISABLE_TOKEN_INSTANCE_SANITIZE_FETCHER=false

# Block indexing settings
FIRST_BLOCK=0
LAST_BLOCK=
TRACE_FIRST_BLOCK=0
TRACE_LAST_BLOCK=

# Block transformer for Clique
BLOCK_TRANSFORMER=clique

# Indexer memory limits
INDEXER_MEMORY_LIMIT=8g

# Batch sizes (adjust based on your hardware)
INDEXER_BLOCK_REFETCH_NEEDED_BATCH_SIZE=10
TOKEN_INSTANCE_OWNER_MIGRATION_CONCURRENCY=5
INDEXER_CATCHUP_BLOCKS_BATCH_SIZE=10
INDEXER_CATCHUP_BLOCKS_CONCURRENCY=10
INDEXER_INTERNAL_TRANSACTIONS_BATCH_SIZE=10
INDEXER_INTERNAL_TRANSACTIONS_CONCURRENCY=4
INDEXER_COIN_BALANCES_BATCH_SIZE=100
INDEXER_COIN_BALANCES_CONCURRENCY=4
INDEXER_RECEIPTS_BATCH_SIZE=50
INDEXER_RECEIPTS_CONCURRENCY=10

# =============================================================================
# TRACING CONFIGURATION (IMPORTANT FOR GETH)
# =============================================================================
# Geth trace method
INDEXER_INTERNAL_TRANSACTIONS_TRACER_TYPE=call_tracer

# Enable debug_traceTransaction
ETHEREUM_JSONRPC_DEBUG_TRACE_TRANSACTION_TIMEOUT=60s

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_V2_ENABLED=true
GRAPHQL_ENABLED=true
# Public URL of the explorer (proxy host:port from docker-compose.yml)
WEBAPP_URL=http://localhost:39001
API_HOST=localhost
API_PORT=4000
API_SCHEME=http

# Rate limiting
API_RATE_LIMIT=50
API_RATE_LIMIT_BY_KEY=50
API_RATE_LIMIT_BY_WHITELISTED_IP=500
# Set a static API key (provided separately)
API_RATE_LIMIT_STATIC_API_KEY=CHANGE_ME
API_RATE_LIMIT_WHITELISTED_IPS=

# =============================================================================
# MICROSERVICES
# =============================================================================
MICROSERVICE_SC_VERIFIER_ENABLED=true
MICROSERVICE_SC_VERIFIER_URL=http://smart-contract-verifier:8050
MICROSERVICE_SC_VERIFIER_TYPE=sc_verifier

MICROSERVICE_VISUALIZE_SOL2UML_ENABLED=true
MICROSERVICE_VISUALIZE_SOL2UML_URL=http://visualizer:8050

MICROSERVICE_SIG_PROVIDER_ENABLED=false
# MICROSERVICE_SIG_PROVIDER_URL=http://sig-provider:8050

# =============================================================================
# DISPLAY SETTINGS
# =============================================================================
LOGO=/images/blockscout_logo.svg
LOGO_FOOTER=/images/blockscout_logo.svg
LOGO_TEXT=Voltuswave Explorer

# Show/hide features
SHOW_PRICE_CHART=false
SHOW_TXS_CHART=true
SHOW_TENDERLY_LINK=false
SHOW_TESTNET_LABEL=false
TESTNET_LABEL_TEXT=Testnet

# Disable external price services (private chain)
DISABLE_EXCHANGE_RATES=true
DISABLE_KNOWN_TOKENS=true
DISABLE_BRIDGE_MARKET_CAP_UPDATER=true

# =============================================================================
# VALIDATORS / SIGNERS DISPLAY (Clique Specific)
# =============================================================================
# Clique PoA doesn't use staking contracts - signers shown in block details
POS_STAKING_CONTRACT=
CHAIN_TYPE=default

# =============================================================================
# ACCOUNT FEATURES (Optional)
# =============================================================================
ACCOUNT_ENABLED=false
# If enabling accounts, configure Auth0:
# ACCOUNT_AUTH0_DOMAIN=
# ACCOUNT_AUTH0_CLIENT_ID=
# ACCOUNT_AUTH0_CLIENT_SECRET=

# =============================================================================
# SECURITY
# =============================================================================
# Generate with: openssl rand -hex 64  (provided separately - DO NOT commit the real value)
SECRET_KEY_BASE=

# Session configuration
SESSION_COOKIE_DOMAIN=localhost

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# CORS is handled by nginx proxy to avoid duplicate headers
# Nginx adds proper CORS headers including updated-gas-oracle
ALLOWED_ORIGINS=
ALLOWED_ORIGINS_READ_ONLY_API=
API_V2_ALLOWED_ORIGINS=

# =============================================================================
# PERFORMANCE
# =============================================================================
HEART_BEAT_TIMEOUT=60
JSON_RPC_TIMEOUT=30000
TIMEOUT=60000
BLOCKSCOUT_PROTOCOL=http
PORT=4000

# =============================================================================
# HISTORY (Token/Coin price history - disabled for private chains)
# =============================================================================
DISABLE_INDEXER=false
DISABLE_REALTIME_INDEXER=false
DISABLE_WEBAPP=false

# =============================================================================
# SOURCIFY (Contract verification via Sourcify)
# =============================================================================
SOURCIFY_INTEGRATION_ENABLED=true
SOURCIFY_SERVER_URL=https://sourcify.dev/server
SOURCIFY_REPO_URL=https://repo.sourcify.dev/contracts

# =============================================================================
# ETHEREUM SPECIFIC (for compatibility)
# =============================================================================
SUPPLY_MODULE=TokenBridge
TOKEN_METADATA_UPDATE_INTERVAL=172800
